# ─────────────────────────────────────────────────────────────
# Senara — Environment Variables
# ─────────────────────────────────────────────────────────────
# Bu dosyayı kopyalayarak `.env` oluşturun:
#   cp .env.example .env
#
# ⚠️  .env dosyası .gitignore'da listelenmiştir.
#     Asla commit'lemeyin, API anahtarlarınızı koruyun.
# ─────────────────────────────────────────────────────────────

# ── AI Servisi ───────────────────────────────────────────────
# Google Gemini API anahtarı.
# https://aistudio.google.com/app/apikey adresinden alınır.
# VITE_USE_MOCK=true iken bu alan boş bırakılabilir.
VITE_GEMINI_API_KEY=

# ── Mock / Gerçek Mod Seçimi ─────────────────────────────────
# true  → Tüm servisler sahte (mock) veri döner. API key gerekmez.
#          Geliştirme ve demo için idealdir.
# false → Gerçek Gemini API + Extension content script'leri aktif olur.
#          Chrome Extension olarak paketlendiğinde false yapın.
##VITE_USE_MOCK=true
