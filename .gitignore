# ─────────────────────────────────────────────────────────────
# Senara — .gitignore
# ─────────────────────────────────────────────────────────────

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Dependencies ─────────────────────────────────────────────
node_modules/

# ── Build output ─────────────────────────────────────────────
dist/
dist-ssr/
.output/
.vinxi/
.tanstack/
.nitro/

# ── Environment & Secrets ────────────────────────────────────
# .env.example repo'da kalır (şablon). Asıl değerler asla push'lanmaz.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.dev.vars

# ── Lockfiles ────────────────────────────────────────────────
# Bun lockfile'ı binary formattır ve büyüktür (~185KB).
# CI/CD ortamında `bun install` ile yeniden oluşturulur.
bun.lock

# ── Wrangler / Cloudflare ────────────────────────────────────
.wrangler/

# ── Chrome Extension artifacts ───────────────────────────────
# Paketlenmiş extension dosyaları ve imza anahtarları
*.crx
*.pem
*.zip

# ── Editor & IDE ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS-generated files ───────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.swp
*~
